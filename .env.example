# ── MQTT ──────────────────────────────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC=hydromind/#

# ── InfluxDB ───────────────────────────────────────────────────────────────────
# In docker-compose, INFLUX_TOKEN must match the DB's init admin token (compose
# defaults both to this value) and the backend auto-overrides the URL to the
# influxdb service name.
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=hydromind-local-token
INFLUX_ORG=hydromind
INFLUX_BUCKET=sensor_readings
# Admin UI password used on first-time InfluxDB setup (min 8 chars).
INFLUX_PASSWORD=changeme123

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=
MONGO_DB=hydromind

# ── OpenWeatherMap ─────────────────────────────────────────────────────────────
OWM_API_KEY=

# ── Sarvam AI (Telugu TTS + translation + chat) ────────────────────────────────
SARVAM_API_KEY=

# ── Google Gemini (situational briefing) ──────────────────────────────────────
GEMINI_API_KEY=

# ── Twilio (SMS + voice calls) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Alert thresholds — river nodes (distance_cm; lower = flood) ──────────────
ALERT_YELLOW_CM=80
ALERT_ORANGE_CM=60
ALERT_RED_CM=40

# ── Alert thresholds — urban drains (fill %) ──────────────────────────────────
DRAIN_WATCH_PCT=60
DRAIN_WARNING_PCT=75
DRAIN_CRITICAL_PCT=85

# ── Sewer safety thresholds (ppm methane) ─────────────────────────────────────
METHANE_CAUTION_PPM=200
METHANE_DANGER_PPM=500
METHANE_CRITICAL_PPM=1000

# ── n8n ───────────────────────────────────────────────────────────────────────
# Set to the workflow's production webhook URL after importing/activating it.
N8N_WEBHOOK_URL=
# n8n editor UI (docker-compose) basic auth + host.
N8N_HOST=localhost
N8N_USER=admin
N8N_PASSWORD=changeme123

# ── Deployment ────────────────────────────────────────────────────────────────
VULTR_HOST=
